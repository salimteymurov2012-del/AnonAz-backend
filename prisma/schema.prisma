generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique
  password    String
  avatar      String?
  gender      String?
  age         Int?
  city        String?
  district    String?
  description String?
  createdAt   DateTime @default(now())
  lastSeen    DateTime @default(now())
  isOnline    Boolean  @default(false)
  isBlocked   Boolean  @default(false)
  role        String   @default("user")

  messagesSent       Message[]   @relation("SentMessages")
  valentinesSent     Valentine[] @relation("SentValentines")
  valentinesReceived Valentine[] @relation("ReceivedValentines")
  reportsFiled       Report[]    @relation("Reporter")
  reportsTargeted    Report[]    @relation("Target")
  favorites          Favorite[]  @relation("UserFavorites")
  favoritedBy        Favorite[]  @relation("FavoritedBy")
}

model Message {
  id         Int      @id @default(autoincrement())
  content    String
  senderId   Int
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  receiverId Int
  replyToId  Int?
  imageUrl   String?
  createdAt  DateTime @default(now())
  isDeleted  Boolean  @default(false)
}

model Valentine {
  id        Int      @id @default(autoincrement())
  fromId    Int
  from      User     @relation("SentValentines", fields: [fromId], references: [id])
  toId      Int
  to        User     @relation("ReceivedValentines", fields: [toId], references: [id])
  text      String
  status    String   @default("pending")
  createdAt DateTime @default(now())
}

model Report {
  id         Int      @id @default(autoincrement())
  reporterId Int
  reporter   User     @relation("Reporter", fields: [reporterId], references: [id])
  targetId   Int
  target     User     @relation("Target", fields: [targetId], references: [id])
  reason     String
  createdAt  DateTime @default(now())
  resolved   Boolean  @default(false)
}

model Favorite {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation("UserFavorites", fields: [userId], references: [id])
  targetId  Int
  target    User     @relation("FavoritedBy", fields: [targetId], references: [id])
  createdAt DateTime @default(now())

  @@unique([userId, targetId])
}
